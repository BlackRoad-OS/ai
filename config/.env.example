# BlackRoad Kanban Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===========================================
# Core Settings
# ===========================================
ENVIRONMENT=development  # development, staging, production
LOG_LEVEL=INFO          # DEBUG, INFO, WARNING, ERROR

# ===========================================
# API Settings
# ===========================================
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# ===========================================
# Cloudflare Integration
# ===========================================
CLOUDFLARE_ENABLED=false
CLOUDFLARE_API_KEY=your_cloudflare_api_key
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_KV_NAMESPACE_ID=your_kv_namespace_id
CLOUDFLARE_D1_DATABASE_ID=your_d1_database_id
CLOUDFLARE_R2_BUCKET=your_r2_bucket

# ===========================================
# Salesforce Integration
# ===========================================
SALESFORCE_ENABLED=false
SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com
SALESFORCE_CLIENT_ID=your_client_id
SALESFORCE_CLIENT_SECRET=your_client_secret
SALESFORCE_USERNAME=your_username
SALESFORCE_API_VERSION=v59.0

# ===========================================
# Vercel Integration
# ===========================================
VERCEL_ENABLED=false
VERCEL_API_KEY=your_vercel_api_key
VERCEL_TEAM_ID=your_team_id
VERCEL_PROJECT_ID=your_project_id
VERCEL_PROJECT_NAME=blackroad-kanban

# ===========================================
# DigitalOcean Integration
# ===========================================
DIGITALOCEAN_ENABLED=false
DIGITALOCEAN_API_KEY=your_do_api_key
DIGITALOCEAN_SPACES_REGION=nyc3
DIGITALOCEAN_SPACES_BUCKET=your_bucket
DIGITALOCEAN_SPACES_KEY=your_spaces_key
DIGITALOCEAN_SPACES_SECRET=your_spaces_secret
DIGITALOCEAN_FUNCTION_NAMESPACE=your_function_namespace

# ===========================================
# Claude (Anthropic) Integration
# ===========================================
CLAUDE_ENABLED=true
ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

# ===========================================
# GitHub Integration
# ===========================================
GITHUB_ENABLED=true
GITHUB_TOKEN=your_github_token
GITHUB_OWNER=your_username_or_org
GITHUB_REPO=your_repo_name
GITHUB_PROJECT_NUMBER=1

# ===========================================
# Termius Integration
# ===========================================
TERMIUS_ENABLED=false
TERMIUS_API_KEY=your_termius_api_key
TERMIUS_TEAM_ID=your_team_id

# ===========================================
# Working Copy Integration
# ===========================================
WORKING_COPY_KEY=your_callback_key

# ===========================================
# Hashing Configuration
# ===========================================
SHA_INFINITY_DEPTH=7
HASH_SALT=your_optional_salt_for_extra_security

# ===========================================
# Database (if using external)
# ===========================================
DATABASE_TYPE=sqlite  # sqlite, postgres
DATABASE_PATH=./data/kanban.db
# For Postgres:
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=kanban
# DATABASE_USER=kanban_user
# DATABASE_PASSWORD=your_password
