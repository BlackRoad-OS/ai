# BlackRoad OS AI — Environment Variables
# Copy this file to .env and fill in your values

# Server
NODE_ENV=development
PORT=3000

# Database (PostgreSQL via Railway or local)
DATABASE_URL=postgresql://user:password@localhost:5432/blackroad_ai

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=xxxxx
CLOUDFLARE_API_TOKEN=xxxxx

# Vercel (set in Vercel dashboard)
# VERCEL_TOKEN=xxxxx

# Railway (set in Railway dashboard)
# RAILWAY_TOKEN=xxxxx
