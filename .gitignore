# BlackRoad Kanban .gitignore
# ===========================

# Environment and secrets
.env
.env.local
.env.*.local
*.pem
*.key
credentials.json
secrets.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# Testing
.coverage
.pytest_cache/
htmlcov/
.tox/
.nox/

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Data (keep structure, ignore content)
data/boards/*.json
data/agents/*.json
data/sync/*.json
!data/.gitkeep

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db

# Local kanban state
.kanban/boards/*.json
!.kanban/.gitkeep

# Temporary files
*.tmp
*.temp
*.bak
